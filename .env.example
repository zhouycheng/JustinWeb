ACTIVITY_MONITOR_TOKEN=replace-with-a-long-random-token
ACTIVITY_MONITOR_URL=http://localhost:4321
ACTIVITY_MONITOR_EXTRA_URLS=
ACTIVITY_MONITOR_POLL_INTERVAL_MS=2000
ACTIVITY_MONITOR_HEARTBEAT_INTERVAL_MS=12000
ACTIVITY_MONITOR_REQUEST_TIMEOUT_MS=4000

# Canvas persistence
CANVAS_AUTH_TOKEN=change-me-to-64-char-hex
CANVAS_DB_PATH=data/canvas.db
CANVAS_ASSET_DIR=data/canvas-assets
JUSTIN_OS_DESKTOP_DIR=

# Immutable canvas backup (enable with COMPOSE_PROFILES=backup)
BACKUP_CRON=5 * * * *
BACKUP_RUN_ON_START=true
BACKUP_KEEP_HOURLY=48
BACKUP_KEEP_DAILY=30
BACKUP_KEEP_WEEKLY=12
BACKUP_KEEP_MONTHLY=12
RESTIC_LOCAL_PASSWORD=replace-with-a-long-local-backup-password
RESTIC_REMOTE_PASSWORD=replace-with-a-different-long-remote-password
RESTIC_REMOTE_REPOSITORY=s3:https://s3.example.com/bucket/justinweb
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# Server sync
# SERVER_HOST=user@your-server.com
