---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import projects from "/src/data/projects.json";

type ProjectLinkKind = "github" | "gitee" | "website" | "docs";

type ProjectLink = {
  kind: ProjectLinkKind;
  label: string;
  href: string;
};

type ProjectRecord = {
  id: string;
  navLabel: string;
  title: string;
  tags: string[];
  description: string;
  lastUpdatedText: string;
  startedText: string;
  preview: {
    src: string;
    alt: string;
  };
  links: ProjectLink[];
};

type PreviewAsset = ImageMetadata | string;

const projectRecords = projects as ProjectRecord[];
const imageModules = import.meta.glob<{ default: PreviewAsset }>(
  "/src/assets/projects/*.{avif,gif,jpeg,jpg,png,svg,webp}",
  { eager: true },
);

function resolvePreviewAsset(path: string) {
  const imageModule = imageModules[path];
  if (!imageModule) {
    throw new Error(`Missing project preview asset: ${path}`);
  }

  const asset = imageModule.default;
  return {
    asset,
    isSvg: path.toLowerCase().endsWith(".svg"),
    url: typeof asset === "string" ? asset : asset.src,
  };
}

function linkGlyph(kind: ProjectLinkKind) {
  if (kind === "github") return "GH";
  if (kind === "gitee") return "G";
  if (kind === "docs") return "Doc";
  return "↗";
}

const portfolioProjects = projectRecords.map((project, index) => ({
  ...project,
  index,
  previewAsset: resolvePreviewAsset(project.preview.src),
}));
---

<section class="works-portfolio" data-works-portfolio aria-label="作品集">
  <nav class="works-portfolio__tabs" aria-label="作品项目">
    {portfolioProjects.map((project) => (
      <button
        class:list={["works-project-tab", project.index === 0 && "is-active"]}
        type="button"
        id={`works-tab-${project.id}`}
        data-project-tab
        data-project-index={project.index}
        aria-controls={`works-project-${project.id}`}
        aria-selected={project.index === 0 ? "true" : "false"}
      >
        <span>{project.navLabel}</span>
      </button>
    ))}
  </nav>

  <div class="works-portfolio__viewport" data-project-viewport tabindex="0">
    {portfolioProjects.map((project) => (
      <article
        class="works-project"
        id={`works-project-${project.id}`}
        data-project-panel
        data-project-index={project.index}
        aria-labelledby={`works-title-${project.id}`}
        aria-hidden={project.index === 0 ? "false" : "true"}
      >
        <div class="works-project__preview">
          <div class="works-project__preview-frame">
            {project.previewAsset.isSvg ? (
              <img
                class="works-project__image"
                src={project.previewAsset.url}
                alt={project.preview.alt}
                loading={project.index === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            ) : (
              <Image
                class="works-project__image"
                src={project.previewAsset.asset as ImageMetadata}
                alt={project.preview.alt}
                loading={project.index === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            )}
          </div>
        </div>

        <div class="works-project__content">
          <h2 id={`works-title-${project.id}`}>{project.title}</h2>

          <ul class="works-project__tags" aria-label={`${project.title} 技术标签`}>
            {project.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>

          <p class="works-project__description">{project.description}</p>

          <div class="works-project__meta">
            <p>{project.lastUpdatedText}</p>
            <p>{project.startedText}</p>
          </div>

          <div class="works-project__links" aria-label={`${project.title} 项目链接`}>
            {project.links.map((link) => (
              <a
                class:list={["works-project-link", `works-project-link--${link.kind}`]}
                href={link.href}
                target="_blank"
                rel="noreferrer"
                aria-label={`${project.title} ${link.label}`}
                title={link.label}
              >
                <span aria-hidden="true">{linkGlyph(link.kind)}</span>
                <span class="works-project-link__label">{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  (() => {
    const roots = document.querySelectorAll("[data-works-portfolio]");

    roots.forEach((root) => {
      const viewport = root.querySelector("[data-project-viewport]");
      const tabs = Array.from(root.querySelectorAll("[data-project-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-project-panel]"));
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!(viewport instanceof HTMLElement) || tabs.length === 0 || panels.length === 0) {
        return;
      }

      let activeIndex = 0;
      let settleTimer = 0;
      let resizeFrame = 0;

      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }

      function panelHeight() {
        return Math.max(1, viewport.clientHeight);
      }

      function setActiveProject(index) {
        const nextIndex = clamp(index, 0, panels.length - 1);
        activeIndex = nextIndex;

        tabs.forEach((tab, tabIndex) => {
          const isActive = tabIndex === nextIndex;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel, panelIndex) => {
          panel.setAttribute("aria-hidden", String(panelIndex !== nextIndex));
        });
      }

      function nearestIndexFromScroll() {
        const rawIndex = viewport.scrollTop / panelHeight();
        const baseIndex = Math.floor(rawIndex);
        const fraction = rawIndex - baseIndex;
        const targetIndex = baseIndex + (fraction > 0.5 ? 1 : 0);
        return clamp(targetIndex, 0, panels.length - 1);
      }

      function scrollToProject(index, behavior = "smooth") {
        const nextIndex = clamp(index, 0, panels.length - 1);
        const top = nextIndex * panelHeight();
        viewport.scrollTo({
          top,
          behavior: reduceMotion ? "auto" : behavior,
        });
        setActiveProject(nextIndex);
      }

      function settleScroll() {
        settleTimer = 0;
        scrollToProject(nearestIndexFromScroll());
      }

      function scheduleSettle() {
        if (settleTimer) {
          window.clearTimeout(settleTimer);
        }
        settleTimer = window.setTimeout(settleScroll, reduceMotion ? 20 : 140);
      }

      viewport.addEventListener("scroll", () => {
        const liveIndex = clamp(Math.round(viewport.scrollTop / panelHeight()), 0, panels.length - 1);
        setActiveProject(liveIndex);
        scheduleSettle();
      }, { passive: true });

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const index = Number(tab.getAttribute("data-project-index") ?? "0");
          scrollToProject(index);
        });
      });

      viewport.addEventListener("keydown", (event) => {
        if (event.key === "ArrowDown" || event.key === "PageDown") {
          event.preventDefault();
          scrollToProject(activeIndex + 1);
        }

        if (event.key === "ArrowUp" || event.key === "PageUp") {
          event.preventDefault();
          scrollToProject(activeIndex - 1);
        }

        if (event.key === "Home") {
          event.preventDefault();
          scrollToProject(0);
        }

        if (event.key === "End") {
          event.preventDefault();
          scrollToProject(panels.length - 1);
        }
      });

      window.addEventListener("resize", () => {
        if (resizeFrame) return;
        resizeFrame = window.requestAnimationFrame(() => {
          resizeFrame = 0;
          scrollToProject(activeIndex, "auto");
        });
      });

      setActiveProject(0);
    });
  })();
</script>

<style>
  :global(#page-works) {
    overflow: hidden;
    background: #fffdf8;
  }

  .works-portfolio {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background: #fffdf8;
    color: #070707;
    font-family: var(--sans);
  }

  .works-portfolio__tabs {
    position: absolute;
    z-index: 4;
    top: clamp(2.4rem, 5.2svh, 3.75rem);
    left: 50%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(2.35rem, 4.2vw, 4.6rem);
    width: min(48rem, calc(100% - 2rem));
    transform: translateX(-50%);
  }

  .works-project-tab {
    position: relative;
    min-width: 0;
    border: 0;
    padding: 0 0 1.55rem;
    background: transparent;
    color: #b4b4b4;
    cursor: pointer;
    font: 500 clamp(1.18rem, 1.74vw, 1.62rem) / 1.08 var(--sans);
    letter-spacing: 0;
    text-align: center;
    white-space: nowrap;
    transition: color 0.18s ease;
  }

  .works-project-tab::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0.58rem;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 999px;
    background: #b7b7b7;
    opacity: 0;
    transform: translateX(-50%) scale(0.62);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .works-project-tab:hover,
  .works-project-tab:focus-visible,
  .works-project-tab.is-active {
    color: #494949;
  }

  .works-project-tab:focus-visible {
    outline: 2px solid rgba(0, 47, 167, 0.42);
    outline-offset: 0.38rem;
  }

  .works-project-tab.is-active::after {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  .works-portfolio__viewport {
    position: relative;
    z-index: 1;
    height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .works-portfolio__viewport:focus {
    outline: 0;
  }

  .works-portfolio__viewport::-webkit-scrollbar {
    display: none;
  }

  .works-project {
    height: 100%;
    min-height: 100%;
    display: grid;
    grid-template-columns: minmax(19rem, 45.2rem) minmax(23rem, 37.5rem);
    align-items: start;
    gap: clamp(2.4rem, 3.5vw, 3.6rem);
    padding:
      clamp(9.8rem, 16.8svh, 10.65rem)
      clamp(4rem, 4.5vw, 4.5rem)
      clamp(7.2rem, 11svh, 8.7rem);
  }

  .works-project__preview {
    min-width: 0;
    display: flex;
    justify-content: flex-start;
  }

  .works-project__preview-frame {
    width: min(45.2rem, 100%);
    aspect-ratio: 0.972;
    overflow: hidden;
    border-radius: 8px;
    background: #d8d8d8;
  }

  .works-project__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .works-project__content {
    min-width: 0;
    width: min(100%, 42rem);
    padding-top: 0.4rem;
  }

  .works-project__content h2 {
    margin: 0;
    color: #050505;
    font: 760 clamp(1.9rem, 2.38vw, 2.18rem) / 1.1 var(--sans);
    letter-spacing: 0;
  }

  .works-project__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.86rem 1.32rem;
    margin: clamp(2.05rem, 3.4svh, 2.45rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .works-project__tags li {
    min-width: clamp(6.8rem, 8.2vw, 7.35rem);
    min-height: 2.12rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.62rem;
    padding: 0.36rem 1rem;
    background: #d6d6d6;
    color: #111111;
    font: 500 1rem / 1.1 var(--sans);
    white-space: nowrap;
  }

  .works-project__description {
    margin: clamp(2.65rem, 4.8svh, 3.15rem) 0 0;
    color: #070707;
    font: 500 clamp(1.05rem, 1.45vw, 1.33rem) / 1.28 var(--sans);
    letter-spacing: 0;
    white-space: pre-line;
  }

  .works-project__meta {
    display: grid;
    gap: 0.58rem;
    margin-top: clamp(2.25rem, 4.1svh, 3rem);
    color: #858585;
    font: 500 clamp(1rem, 1.28vw, 1.27rem) / 1.2 var(--sans);
  }

  .works-project__meta p {
    margin: 0;
  }

  .works-project__links {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 2.2vw, 2rem);
    margin-top: clamp(2rem, 3.4svh, 2.42rem);
  }

  .works-project-link {
    width: 2.62rem;
    height: 2.62rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #151515;
    color: #ffffff;
    font: 850 0.78rem / 1 var(--sans);
    letter-spacing: 0;
    transition:
      transform 0.18s cubic-bezier(0.2, 0.82, 0.18, 1),
      box-shadow 0.18s ease;
  }

  .works-project-link:hover,
  .works-project-link:focus-visible {
    outline: 0;
    transform: translateY(-0.12rem);
    box-shadow: 0 0.5rem 1.3rem rgba(30, 30, 30, 0.16);
  }

  .works-project-link:focus-visible {
    outline: 2px solid rgba(0, 47, 167, 0.42);
    outline-offset: 0.22rem;
  }

  .works-project-link--gitee {
    background: #cf1f29;
    font-size: 1.26rem;
  }

  .works-project-link--website,
  .works-project-link--docs {
    background: var(--blue);
  }

  .works-project-link__label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 1180px) {
    .works-project {
      grid-template-columns: minmax(17rem, 0.9fr) minmax(21rem, 0.78fr);
      gap: clamp(2rem, 4vw, 3.4rem);
      padding-inline: clamp(2rem, 4.8vw, 4rem);
    }

    .works-project__preview-frame {
      width: min(39rem, 100%);
    }
  }

  @media (max-width: 860px) {
    .works-portfolio__tabs {
      top: clamp(1.3rem, 3.6svh, 2rem);
      justify-content: flex-start;
      gap: 1.65rem;
      width: 100%;
      padding: 0 1.05rem 0.35rem;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .works-portfolio__tabs::-webkit-scrollbar {
      display: none;
    }

    .works-project-tab {
      flex: 0 0 auto;
      padding-bottom: 1.25rem;
      font-size: clamp(1rem, 5vw, 1.28rem);
    }

    .works-project {
      grid-template-columns: 1fr;
      grid-template-rows: auto minmax(0, 1fr);
      gap: clamp(1rem, 2.8svh, 1.45rem);
      padding:
        clamp(5.35rem, 10svh, 6.2rem)
        clamp(1rem, 5vw, 1.45rem)
        clamp(5.45rem, 10svh, 6.25rem);
    }

    .works-project__preview {
      justify-content: center;
    }

    .works-project__preview-frame {
      width: min(100%, 31rem);
      max-height: min(34svh, 18rem);
      aspect-ratio: 1.18;
    }

    .works-project__content {
      width: 100%;
      padding-top: 0;
    }

    .works-project__content h2 {
      font-size: clamp(1.65rem, 8vw, 2rem);
    }

    .works-project__tags {
      gap: 0.55rem;
      margin-top: 1.05rem;
    }

    .works-project__tags li {
      min-width: 0;
      min-height: 1.88rem;
      border-radius: 0.5rem;
      padding: 0.32rem 0.78rem;
      font-size: 0.88rem;
    }

    .works-project__description {
      display: -webkit-box;
      overflow: hidden;
      margin-top: 1.25rem;
      font-size: clamp(0.92rem, 4.1vw, 1.02rem);
      line-height: 1.32;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 6;
    }

    .works-project__meta {
      gap: 0.32rem;
      margin-top: 1.05rem;
      font-size: 0.9rem;
    }

    .works-project__links {
      gap: 1rem;
      margin-top: 1rem;
    }

    .works-project-link {
      width: 2.32rem;
      height: 2.32rem;
      font-size: 0.72rem;
    }

    .works-project-link--gitee {
      font-size: 1.12rem;
    }
  }

  @media (max-width: 430px) {
    .works-project {
      padding-inline: 0.84rem;
      padding-bottom: 5.95rem;
    }

    .works-project__preview-frame {
      max-height: 30svh;
    }

    .works-project__description {
      -webkit-line-clamp: 5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .works-portfolio__viewport {
      scroll-behavior: auto;
    }

    .works-project-tab,
    .works-project-tab::after,
    .works-project-link {
      transition-duration: 1ms;
    }
  }
</style>
