---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Justin OS",
  description = "Justin 的个人 OS 与组件库 Justin Kit。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
