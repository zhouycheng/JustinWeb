{
  "name": "astro-justin-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "dev:full": "(sleep 3 && node src/justin-kit/components/local-activity-status/scripts/activity-monitor.mjs) & astro dev --host 0.0.0.0 --port 4321; kill %1 2>/dev/null",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "monitor:activity": "node src/justin-kit/components/local-activity-status/scripts/activity-monitor.mjs",
    "db:backup": "docker compose --profile backup run --rm canvas-backup /opt/backup/backup.sh",
    "db:backup:check": "docker compose --profile backup run --rm canvas-backup /opt/backup/check.sh",
    "db:restore": "docker compose --profile backup run --rm canvas-backup /opt/backup/restore.sh"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@floating-ui/react": "^0.27.19",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@xyflow/react": "^12.11.1",
    "astro": "^7.0.3",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3"
  }
}
